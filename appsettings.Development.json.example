{
  "//": "Copy to appsettings.Development.json (gitignored) and fill in. Resolve the values from your POC resource group the same way scripts/generate-grandma.sh does:",
  "//1": "  OAI: az cognitiveservices account show -g <rg> -n <account> --query 'properties.endpoints.\"OpenAI Sora API\"' -o tsv",
  "//2": "  KEY: az cognitiveservices account keys list -g <rg> -n <account> --query key1 -o tsv",
  "Parameters": {
    "sora-endpoint": "https://<your-foundry-account>.openai.azure.com/",
    "sora-api-key": "<key1>",
    "sora-deployment": "sora-2",
    "stripe-secret-key": "sk_test_<from-stripe-dashboard>",
    "stripe-webhook-secret": "whsec_<from-stripe-listen>",
    "stripe-price-id": "price_<999-per-month-5-credits>"
  },
  "//3": "Stripe (test mode): secret key from the Stripe dashboard; price id of the $9.99/month plan; webhook signing secret from `stripe listen --forward-to http://localhost:3000/api/stripe/webhook`."
}
