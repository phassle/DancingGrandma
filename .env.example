# DancingGrandma local environment
#
# Copy this file to `.env.local` for `npm run dev`.
# Do not commit `.env.local` or real secrets.

###############################################################################
# Video providers
###############################################################################

# fal.ai is the default real render provider for Wan Animate / Kling Motion Control.
# Get a server-side API key from:
# https://fal.ai/dashboard/keys
FAL_KEY=

# Replicate is the fallback hosted Wan Animate provider.
# Get an API token from:
# https://replicate.com/account/api-tokens
# Model/API reference:
# https://replicate.com/wan-video/wan-2.2-animate-animation/api
REPLICATE_API_TOKEN=

# Optional: override the Replicate model slug used by `src/app/api/providers/replicate`.
REPLICATE_WAN_ANIMATE_MODEL=wan-video/wan-2.2-animate-animation

# Optional: poll interval for Replicate provider route, in milliseconds.
# Keep the default for real runs; tests set this to 0.
REPLICATE_POLL_MS=5000

###############################################################################
# Azure video provider (coming-soon path)
###############################################################################

# The Azure path is currently kept behind the provider seam until a character
# animation / replacement-capable Azure model contract is confirmed.
#
# Azure AI Foundry:
# https://ai.azure.com/
#
# Azure portal:
# https://portal.azure.com/
#
# Azure OpenAI / Foundry video-generation docs:
# https://learn.microsoft.com/azure/ai-foundry/openai/concepts/video-generation
SORA_ENDPOINT=https://<your-foundry-or-openai-resource>.openai.azure.com/
SORA_API_KEY=
SORA_DEPLOYMENT=sora-2

###############################################################################
# Aspire-provisioned resources
###############################################################################

# `aspire run` injects these connection strings automatically for the apphost
# resource graph. Fill them manually only when running the Next.js app without
# Aspire but still exercising the server-side database/blob helpers.

# Azure Database for PostgreSQL / local Postgres connection string.
# Azure portal:
# https://portal.azure.com/
# Azure PostgreSQL Flexible Server docs:
# https://learn.microsoft.com/azure/postgresql/flexible-server/
ConnectionStrings__grandmadb=Host=localhost;Port=5432;Database=grandmadb;Username=postgres;Password=postgres

# Azure Blob Storage / Azurite connection string.
# Azure Storage accounts:
# https://portal.azure.com/#view/HubsExtension/BrowseResource/resourceType/Microsoft.Storage%2FStorageAccounts
# Connection string docs:
# https://learn.microsoft.com/azure/storage/common/storage-configure-connection-string
ConnectionStrings__videos=UseDevelopmentStorage=true

###############################################################################
# Local platform services
###############################################################################

# Aspire orchestrates the local Next.js app, Postgres, Azurite, and Keycloak.
# Aspire docs:
# https://aspire.dev/
#
# Keycloak docs:
# https://www.keycloak.org/documentation
#
# The local Keycloak URL is assigned by Aspire at runtime and is visible in the
# Aspire dashboard. Do not hard-code a localhost port here unless you run
# Keycloak outside Aspire.
