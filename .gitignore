# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# machine-local Claude Code permissions
.claude/settings.local.json

# machine-local secrets / identifiers — never commit (public repo)
.claude/az-rg-allow.local
infra/main.bicepparam
infra/*.local.bicepparam
appsettings.Development.json

# aspire apphost build artifacts
/artifacts/
/.aspire/

# graphify machine-local state (the graph outputs themselves are committed)
graphify-out/cache/
graphify-out/cost.json
graphify-out/.graphify_*
!graphify-out/.graphify_labels.json
graphify-out/20*/

# agent worktrees are machine-local checkouts, never repo content
.claude/worktrees/

# Trending-dance reference clips ship with the repo so every card renders for
# real on a fresh clone. See public/dances/README.md for the roster and the
# licensing note. Any other files dropped in here stay local.
public/dances/*
!public/dances/README.md
!public/dances/*.mp4

# Editor/IDE config is machine-local (personal absolute paths, per-tool)
.vscode/
